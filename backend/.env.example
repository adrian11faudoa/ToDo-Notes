# backend/.env.example
# Copy to .env for local development (never commit .env to git)
# All fields with defaults are optional unless marked REQUIRED.

# ── App ───────────────────────────────────────────────────────────
APP_NAME=NoteFlow
APP_VERSION=1.0.0
ENVIRONMENT=development          # development | staging | production
DEBUG=true
LOG_LEVEL=debug                  # debug | info | warning | error

# ── API ───────────────────────────────────────────────────────────
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
RATE_LIMIT_PER_MINUTE=120
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# ── Auth ──────────────────────────────────────────────────────────
SECRET_KEY=local-dev-secret-key-change-in-production   # REQUIRED in prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (RDS PostgreSQL) ─────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=noteflow
DATABASE_USER=noteflow
DATABASE_PASSWORD=dev_password     # REQUIRED
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false                # set true to log all SQL queries

# ── Redis (ElastiCache) ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=dev_redis_password
REDIS_DB=0
REDIS_SSL=false                   # true in production (ElastiCache TLS)

# ── AWS General ───────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
AWS_ACCESS_KEY_ID=test            # LocalStack uses 'test'
AWS_SECRET_ACCESS_KEY=test        # LocalStack uses 'test'

# ── S3 ────────────────────────────────────────────────────────────
S3_BUCKET_ATTACHMENTS=noteflow-attachments-local
S3_BUCKET_EXPORTS=noteflow-exports-local
S3_PRESIGNED_URL_EXPIRY=3600      # seconds (1 hour)

# ── AWS Secrets Manager ───────────────────────────────────────────
# Leave empty locally; set to your secret ARN in production.
# When set, overrides DATABASE_PASSWORD, SECRET_KEY, REDIS_PASSWORD at startup.
SECRETS_MANAGER_ARN=

# ── SES (email notifications) ────────────────────────────────────
SES_FROM_EMAIL=noreply@noteflow.app
SES_ENABLED=false

# ── SNS (push notifications) ──────────────────────────────────────
SNS_TOPIC_ARN=

# ── CloudWatch ────────────────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=/noteflow/api
CLOUDWATCH_METRICS_NAMESPACE=NoteFlow/API

# ── Celery (background tasks — optional) ─────────────────────────
# Defaults to REDIS_URL if left empty.
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# ── Sentry (error tracking) ───────────────────────────────────────
SENTRY_DSN=
